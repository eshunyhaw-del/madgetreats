---
import WhatsAppButton from "./WhatsAppButton.astro";

const nav = [
  { label: "Home", href: "/" },
  { label: "Menu", href: "/menu" },
  { label: "About", href: "/about" },
  { label: "Contact", href: "/contact" },
];

const socials = [
  { label: "Instagram", href: "https://instagram.com" },
  { label: "WhatsApp", href: "https://wa.me/233596045710" },
];
---

<footer data-nav="light" class="bg-cream text-brown border-t border-brown/10">
  <div class="mx-auto max-w-[1400px] px-6 lg:px-10 pt-20 lg:pt-28 pb-10">
    <!-- Newsletter / CTA -->
    <div class="grid gap-12 lg:grid-cols-2 lg:items-end">
      <div>
        <p class="eyebrow text-brown/50 mb-6">Stay in the loop</p>
        <h2 class="display text-[clamp(2.2rem,6vw,4.5rem)] max-w-[14ch]">
          Hungry for something special?
        </h2>
        <p class="mt-5 max-w-md text-brown/65 leading-relaxed">
          Let's make your moment sweet.
        </p>
        <div class="mt-8">
          <WhatsAppButton
            message="Hi Madge Treats! I'd like to place an order."
            label="Order on WhatsApp"
            variant="brown"
          />
        </div>
      </div>

      <!-- Logo -->
      <div class="lg:text-right">
        <a href="/" aria-label="Madge Treats — home" class="inline-flex">
          <img
            src="/img/MADGE-TREAT-WEB-LOGO-229-X-62-PIXELS-PRIMARY.png"
            alt="Madge Treats"
            width="229"
            height="62"
            class="footer-logo"
          />
        </a>
      </div>
    </div>

    <!-- Links row -->
    <div class="mt-20 grid gap-10 sm:grid-cols-2 lg:grid-cols-4 border-t border-brown/10 pt-12">
      <div>
        <p class="eyebrow text-brown/40 mb-4">Navigate</p>
        <ul class="space-y-2">
          {
            nav.map((n) => (
              <li>
                <a href={n.href} class="text-brown/75 hover:text-brown transition-colors">
                  {n.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <p class="eyebrow text-brown/40 mb-4">Social</p>
        <ul class="space-y-2">
          {
            socials.map((s) => (
              <li>
                <a
                  href={s.href}
                  target="_blank"
                  rel="noopener"
                  data-no-transition
                  class="text-brown/75 hover:text-brown transition-colors"
                >
                  {s.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <p class="eyebrow text-brown/40 mb-4">Visit</p>
        <p class="text-brown/75 leading-relaxed">
          MQ63+3JW, Taifa<br />
          Accra, Ghana<br />
          Mon – Sat · 9am – 5pm<br />
          Sunday closed
        </p>
      </div>

      <div>
        <p class="eyebrow text-brown/40 mb-4">Order</p>
        <p class="text-brown/75 leading-relaxed">
          WhatsApp / Call<br />
          059 604 5710
        </p>
      </div>
    </div>

    <!-- Copyright -->
    <div class="mt-14 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-brown/50">
      <p>©Madge Treats 2026. Baked with love in Ghana.</p>
    </div>
  </div>
</footer>

<style>
  .footer-logo {
    height: 50px;
    width: auto;
    display: block;
  }
  @media (max-width: 768px) {
    .footer-logo { height: 32px; }
  }
</style>
