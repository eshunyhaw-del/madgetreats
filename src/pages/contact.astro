---
import Layout from "../layouts/Layout.astro";

const orderHref = `https://wa.me/233596045710?text=${encodeURIComponent(
  "Hi Madge Treats! I’d like to place an order. Can you help me?"
)}`;

const details = [
  { label: "WhatsApp / Call", value: "059 604 5710", href: "https://wa.me/233596045710" },
  { label: "Email", value: "hello@madgetreats.com", href: "mailto:hello@madgetreats.com" },
  { label: "Address", value: "MQ63+3JW, Taifa, Accra" },
  { label: "Hours", value: "Mon – Sat · 9am – 5pm (Sun closed)" },
];

const socials = [
  { label: "Instagram", href: "https://instagram.com" },
  { label: "WhatsApp", href: "https://wa.me/233596045710" },
];
---

<Layout
  title="Contact — Madge Treats"
  description="Get in touch with Madge Treats in Taifa, Accra. Order cookies and cakes over WhatsApp on 059 604 5710."
>
  <header data-nav="dark" class="bg-brown text-cream pt-40 pb-20 lg:pt-52 lg:pb-28">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <p class="eyebrow text-yellow mb-6" data-aos="fade-up">Get in touch</p>
      <h1 class="display text-[clamp(3rem,11vw,9rem)] max-w-[16ch]" data-aos="fade-up" data-aos-delay="100">
        Let’s make something sweet together.
      </h1>
      <p class="mt-8 max-w-xl text-lg text-cream/70" data-aos="fade-up" data-aos-delay="200">
        Have a special occasion coming up? Want to know our prices? We’re just a WhatsApp message away.
      </p>
    </div>
  </header>

  <section data-nav="light" class="bg-cream text-brown">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10 py-20 lg:py-28 grid gap-16 lg:grid-cols-2">
      <!-- Details -->
      <div data-aos="fade-up">
        <h2 class="display text-[clamp(2rem,5vw,3.5rem)] mb-10">Reach us</h2>
        <dl class="divide-y divide-brown/10 border-y border-brown/10">
          {
            details.map((d) => (
              <div class="flex items-baseline justify-between gap-6 py-5">
                <dt class="eyebrow text-brown/45">{d.label}</dt>
                <dd class="text-right text-lg">
                  {d.href ? (
                    <a
                      href={d.href}
                      target="_blank"
                      rel="noopener"
                      data-no-transition
                      class="hover:text-yellow-deep transition-colors"
                    >
                      {d.value}
                    </a>
                  ) : (
                    d.value
                  )}
                </dd>
              </div>
            ))
          }
        </dl>

        <div class="mt-10 flex flex-wrap gap-3">
          {
            socials.map((s) => (
              <a
                href={s.href}
                target="_blank"
                rel="noopener"
                data-no-transition
                class="btn btn-outline text-sm py-2.5 px-5"
              >
                {s.label}
              </a>
            ))
          }
        </div>
      </div>

      <!-- Order CTA card -->
      <div
        class="rounded-3xl bg-brown text-cream p-10 lg:p-14 flex flex-col justify-center"
        data-aos="fade-up"
        data-aos-delay="120"
      >
        <h2 class="display text-[clamp(2rem,5vw,3.5rem)] max-w-[14ch]">
          Ready to order?
        </h2>
        <p class="mt-5 text-cream/70 leading-relaxed max-w-sm">
          Tell us what you’d love, when you need it, and where to send it, we’ll handle the rest.
        </p>
        <p class="mt-6 text-cream/50 text-sm">Based in Ghana 🇬🇭</p>
        <div class="mt-8" style="display: block; width: 100%; text-align: left;">
          <a
            href={orderHref}
            target="_blank"
            rel="noopener"
            data-no-transition
            style="display: inline-flex !important;
                   width: auto !important;
                   max-width: 220px !important;
                   min-width: 0 !important;
                   align-items: center;
                   gap: 8px;
                   padding: 14px 24px;
                   background-color: #25D366;
                   color: #ffffff;
                   font-size: 1rem;
                   font-weight: 500;
                   border-radius: 50px;
                   text-decoration: none;
                   box-sizing: border-box;
                   white-space: nowrap;"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path
                d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.945C.157 5.335 5.495 0 12.05 0a11.82 11.82 0 018.413 3.488 11.824 11.824 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 001.51 5.26l-.999 3.648 3.978-1.207zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.247-.694.247-1.289.173-1.413z"
              ></path>
            </svg>
            WhatsApp Us
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
