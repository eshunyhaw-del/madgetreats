---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import StorySection from "../components/StorySection.astro";
import BannerFullbleed from "../components/BannerFullbleed.astro";
import Testimonials from "../components/Testimonials.astro";

const phone = "233596045710";
function waLink(msg: string) {
  return `https://wa.me/${phone}?text=${encodeURIComponent(msg)}`;
}

const products = [
  {
    name: "Red Velvet Cake",
    blurb:
      "A stunning crimson cake layered with smooth cream cheese frosting. Made for moments that deserve to be remembered.",
    message:
      "Hi Madge Treats! I'd like to order a Red Velvet Cake. Can you help me with pricing and sizes?",
    image:
      "https://images.pexels.com/photos/17321240/pexels-photo-17321240.jpeg?auto=compress&cs=tinysrgb&w=800",
  },
  {
    name: "Classic Chocolate Chip Cookies",
    blurb:
      "Crispy on the outside, chewy on the inside. Our signature cookies are impossible to stop at one.",
    message:
      "Hi Madge Treats! I'd like to order Classic Chocolate Chip Cookies. Can you help me with pricing and sizes?",
    image:
      "https://images.pexels.com/photos/31412336/pexels-photo-31412336.jpeg?auto=compress&cs=tinysrgb&w=800",
  },
  {
    name: "Birthday Cake",
    blurb:
      "Make their day unforgettable. Custom birthday cakes baked fresh and decorated just for your celebration.",
    message:
      "Hi Madge Treats! I'd like to order a Birthday Cake. Can you help me with pricing and sizes?",
    image:
      "https://images.pexels.com/photos/4600633/pexels-photo-4600633.jpeg?auto=compress&cs=tinysrgb&w=800",
  },
  {
    name: "Vanilla Cake",
    blurb:
      "Light, fluffy, and perfectly sweet. Our classic vanilla cake is a timeless favourite for every occasion.",
    message:
      "Hi Madge Treats! I'd like to order a Vanilla Cake. Can you help me with pricing and sizes?",
    image:
      "https://images.pexels.com/photos/4110006/pexels-photo-4110006.jpeg?auto=compress&cs=tinysrgb&w=800",
  },
];
---

<Layout>
  <Hero />

  <StorySection />

  <!-- Products / entrypoint section -->
  <section data-nav="light" class="bg-cream text-brown">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10 py-24 lg:py-36">
      <div class="max-w-3xl mb-16 lg:mb-24" data-aos="fade-up">
        <p class="eyebrow text-brown/50 mb-6">The menu</p>
        <h2 class="display text-[clamp(2.8rem,8vw,7rem)]">
          Real flavours,<br />real joy.
        </h2>
        <p class="mt-8 max-w-xl text-lg text-brown/65 leading-relaxed">
          Every bite tells a story. What's yours?
        </p>
      </div>

      <div class="grid gap-8 lg:gap-10 md:grid-cols-2">
        {
          products.map((p, i) => (
            <article
              class="product-card group rounded-3xl border border-brown/10 overflow-hidden bg-white/50 flex flex-col hover:border-brown/25 transition-colors duration-300"
              data-aos="fade-up"
              data-aos-delay={(i % 2) * 120}
            >
              <!-- Image with cinematic hover overlay -->
              <div class="product-media relative overflow-hidden" style="height:380px;">
                <img
                  src={p.image}
                  alt={p.name}
                  loading="lazy"
                  class="w-full h-full object-cover"
                />
                <div class="absolute inset-0 bg-brown/0 group-hover:bg-brown/30 transition-colors duration-500 pointer-events-none" />
              </div>

              <!-- Content -->
              <div class="p-8 flex flex-col gap-4 flex-1">
                <h3 class="font-display text-[1.9rem] leading-tight">{p.name}</h3>
                <p class="text-brown/65 leading-relaxed">{p.blurb}</p>
                <div class="mt-auto pt-2">
                  <a
                    href={waLink(p.message)}
                    target="_blank"
                    rel="noopener"
                    data-no-transition
                    class="inline-flex items-center gap-2 rounded-full px-6 py-3 text-sm font-medium text-white transition-all duration-200 hover:scale-105"
                    style="background-color:#25D366;"
                  >
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.945C.157 5.335 5.495 0 12.05 0a11.82 11.82 0 018.413 3.488 11.824 11.824 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 001.51 5.26l-.999 3.648 3.978-1.207zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.247-.694.247-1.289.173-1.413z"/>
                    </svg>
                    Order on WhatsApp
                  </a>
                </div>
              </div>
            </article>
          ))
        }
      </div>

      <div class="mt-20 flex justify-center" data-aos="fade-up">
        <a href="/menu" class="btn btn-brown">See the full menu</a>
      </div>
    </div>
  </section>

  <BannerFullbleed text="The sweetest moments start here." />

  <Testimonials />
</Layout>
