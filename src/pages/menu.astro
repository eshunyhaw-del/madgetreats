---
import Layout from "../layouts/Layout.astro";

const phone = "233596045710";

function waLink(msg: string) {
  return `https://wa.me/${phone}?text=${encodeURIComponent(msg)}`;
}

const cookies = [
  {
    name: "Classic Chocolate Chip Cookies",
    image: "https://images.pexels.com/photos/17192341/pexels-photo-17192341.jpeg?auto=compress&cs=tinysrgb&w=800",
  },
  {
    name: "The Red Queen Cookies",
    image: "https://images.pexels.com/photos/16974019/pexels-photo-16974019.jpeg?auto=compress&cs=tinysrgb&w=800",
  },
  {
    name: "Lemon Melt Cookies",
    image: "https://images.pexels.com/photos/29611020/pexels-photo-29611020.jpeg?auto=compress&cs=tinysrgb&w=800",
  },
  {
    name: "Golden Oat Crunch Cookies",
    image: "https://images.pexels.com/photos/5436476/pexels-photo-5436476.jpeg?auto=compress&cs=tinysrgb&w=800",
  },
];

const cookieSizes = ["350g", "500g"];

const cakeFlavours = [
  "Vanilla",
  "Red Velvet",
  "Chocolate",
  "Lemon",
  "Black Forest",
  "Biscoff Cake",
];

const cakeSizes = [
  "6 Inches",
  "7 Inches",
  "8 Inches",
  "10 Inches",
  "12 Inches",
];

const occasions = [
  "Birthdays",
  "Anniversaries",
  "Weddings",
  "Corporate / Office",
  "Romantic Celebrations",
];
---

<Layout
  title="Menu — Madge Treats"
  description="Browse the Madge Treats menu — handcrafted cookies and cakes baked fresh in Taifa, Accra. Order in two taps over WhatsApp."
>

  <!-- ── Page header ── -->
  <header data-nav="dark" class="bg-brown text-cream pt-40 pb-20 lg:pt-52 lg:pb-28">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <a
        href="/"
        class="inline-flex items-center gap-2 text-cream/55 hover:text-cream text-sm transition-colors mb-10 group"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="transition-transform group-hover:-translate-x-1">
          <path d="M19 12H5M12 5l-7 7 7 7"/>
        </svg>
        Back to Home
      </a>
      <p class="eyebrow text-yellow mb-6" data-aos="fade-up">What we bake</p>
      <h1
        class="display text-[clamp(3.5rem,12vw,10rem)]"
        data-aos="fade-up"
        data-aos-delay="100"
      >
        Our Menu
      </h1>
      <p
        class="mt-8 max-w-lg text-lg text-cream/65 leading-relaxed"
        data-aos="fade-up"
        data-aos-delay="200"
      >
        Every treat is made by hand, baked fresh, and crafted to make your moment unforgettable.
      </p>
    </div>
  </header>

  <!-- ══════════════════════════════════════════
       SECTION 1 — COOKIES
  ══════════════════════════════════════════ -->
  <section data-nav="light" class="bg-cream text-brown">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10 py-24 lg:py-36">

      <!-- Section heading -->
      <div class="border-b border-brown/12 pb-10 mb-16" data-aos="fade-up">
        <p class="eyebrow text-brown/45 mb-5">Section 01</p>
        <h2 class="display text-[clamp(3.5rem,11vw,9rem)]">Cookies</h2>
        <p class="mt-5 max-w-lg text-lg text-brown/60 leading-relaxed">Crispy, chewy, and impossible to stop at one.</p>
      </div>

      <!-- Cookie cards -->
      <div class="grid gap-8 sm:grid-cols-2">
        {cookies.map((cookie, i) => (
          <article
            class="group rounded-3xl border border-brown/10 overflow-hidden bg-white/50 flex flex-col hover:border-brown/25 transition-colors duration-300"
            data-aos="fade-up"
            data-aos-delay={i * 100}
          >
            <!-- Image with cinematic overlay -->
            <div class="relative overflow-hidden" style="height:280px;">
              <img
                src={cookie.image}
                alt={cookie.name}
                loading="lazy"
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              />
              <!-- Dark overlay fades in on hover -->
              <div class="absolute inset-0 bg-brown/0 group-hover:bg-brown/30 transition-colors duration-500 pointer-events-none" />
            </div>

            <!-- Content -->
            <div class="p-7 flex flex-col gap-5 flex-1">
              <h3 class="font-display text-[1.65rem] leading-snug">{cookie.name}</h3>

              <!-- Size buttons -->
              <div class="flex flex-wrap gap-2">
                {cookieSizes.map((size) => (
                  <a
                    href={waLink(`Hi Madge Treats! I'd like to know the price of ${cookie.name} - ${size}`)}
                    target="_blank"
                    rel="noopener"
                    data-no-transition
                    class="rounded-full border border-brown/20 px-4 py-2.5 text-sm font-medium text-brown hover:bg-brown hover:text-cream hover:border-brown transition-all duration-200"
                  >
                    {size}
                  </a>
                ))}
              </div>

              <!-- WhatsApp CTA -->
              <div class="mt-auto pt-2">
                <a
                  href={waLink(`Hi Madge Treats! I'd like to order the ${cookie.name}. Can you help me with pricing?`)}
                  target="_blank"
                  rel="noopener"
                  data-no-transition
                  class="inline-flex items-center gap-2 rounded-full px-5 py-3 text-sm font-medium text-white transition-all duration-200 hover:scale-105"
                  style="background-color:#25D366;"
                >
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.945C.157 5.335 5.495 0 12.05 0a11.82 11.82 0 018.413 3.488 11.824 11.824 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 001.51 5.26l-.999 3.648 3.978-1.207zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.247-.694.247-1.289.173-1.413z"/>
                  </svg>
                  Order on WhatsApp
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       SECTION 2 — CAKES
  ══════════════════════════════════════════ -->
  <section data-nav="dark" class="bg-brown text-cream">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10 py-24 lg:py-36">

      <!-- Section heading -->
      <div class="border-b border-cream/12 pb-10 mb-16" data-aos="fade-up">
        <p class="eyebrow text-yellow mb-5">Section 02</p>
        <h2 class="display text-[clamp(3.5rem,11vw,9rem)] text-cream">Cakes</h2>
        <p class="mt-5 max-w-lg text-lg text-cream/60 leading-relaxed">Too pretty to eat. Too delicious not to.</p>
      </div>

      <!-- Flavours + Sizes side by side -->
      <div class="grid gap-10 lg:grid-cols-2 lg:gap-16">

        <!-- Flavours -->
        <div data-aos="fade-up" data-aos-delay="80">
          <p class="eyebrow text-cream/45 mb-8">Flavours</p>
          <ul class="divide-y divide-cream/10 border-y border-cream/10">
            {cakeFlavours.map((flavour) => (
              <li class="py-5">
                <span class="font-display text-[1.6rem] text-cream">{flavour}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Sizes + CTA -->
        <div data-aos="fade-up" data-aos-delay="160">
          <p class="eyebrow text-cream/45 mb-8">Sizes</p>
          <ul class="divide-y divide-cream/10 border-y border-cream/10 mb-12">
            {cakeSizes.map((size) => (
              <li class="py-5">
                <span class="font-display text-[1.6rem] text-cream">{size}</span>
              </li>
            ))}
          </ul>

          <p class="text-cream/60 leading-relaxed mb-8 max-w-sm">
            Mix and match any flavour with any size. Custom tiers, fillings and
            decorations available — just ask.
          </p>

          <a
            href={waLink("Hi Madge Treats! I'd like to order a cake. Please help me with pricing and availability.")}
            target="_blank"
            rel="noopener"
            data-no-transition
            class="btn btn-yellow inline-flex items-center gap-2"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.945C.157 5.335 5.495 0 12.05 0a11.82 11.82 0 018.413 3.488 11.824 11.824 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 001.51 5.26l-.999 3.648 3.978-1.207zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.247-.694.247-1.289.173-1.413z"/>
            </svg>
            Order a Cake
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       SECTION 3 — OCCASIONS
  ══════════════════════════════════════════ -->
  <section data-nav="light" class="bg-cream text-brown">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10 py-24 lg:py-36">

      <!-- Section heading -->
      <div class="border-b border-brown/12 pb-10 mb-16" data-aos="fade-up">
        <p class="eyebrow text-brown/45 mb-5">Section 03</p>
        <h2 class="display text-[clamp(2.6rem,9vw,7.5rem)] max-w-[14ch]">
          We Bake for Every Occasion
        </h2>
        <p class="mt-5 max-w-lg text-lg text-brown/60 leading-relaxed">From birthdays to weddings, we make every celebration sweeter.</p>
      </div>

      <!-- Occasion grid -->
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {occasions.map((occasion, i) => (
          <article
            class="group relative overflow-hidden rounded-3xl border border-brown/10 bg-white/50 p-8 lg:p-10 flex flex-col gap-8 hover:bg-brown hover:text-cream transition-colors duration-500"
            data-aos="fade-up"
            data-aos-delay={i * 80}
          >
            <span class="display text-[4rem] text-brown/10 group-hover:text-cream/10 leading-none select-none transition-colors duration-500">
              0{i + 1}
            </span>
            <h3 class="font-display text-[1.8rem] leading-tight">{occasion}</h3>
            <a
              href={waLink(`Hi Madge Treats! I'd like to order a cake for ${occasion}. Can you help me?`)}
              target="_blank"
              rel="noopener"
              data-no-transition
              class="mt-auto self-start inline-flex items-center gap-2 rounded-full border border-current px-5 py-2.5 text-sm font-medium transition-all duration-300 hover:scale-105"
            >
              <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.945C.157 5.335 5.495 0 12.05 0a11.82 11.82 0 018.413 3.488 11.824 11.824 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 001.51 5.26l-.999 3.648 3.978-1.207zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.247-.694.247-1.289.173-1.413z"/>
              </svg>
              Order for {occasion}
            </a>
          </article>
        ))}

        <!-- Filler CTA card -->
        <article
          class="rounded-3xl bg-yellow text-brown p-8 lg:p-10 flex flex-col justify-between gap-8 sm:col-span-2 lg:col-span-1"
          data-aos="fade-up"
          data-aos-delay={occasions.length * 80}
          style="background-color:#FFC9FB;"
        >
          <h3 class="font-display text-[1.8rem] leading-tight">Something else in mind?</h3>
          <p class="text-brown/70 leading-relaxed">
            Custom orders, hampers, corporate gifting, just describe what you need.
          </p>
          <a
            href={waLink("Hi Madge Treats! I have a custom order request.")}
            target="_blank"
            rel="noopener"
            data-no-transition
            class="self-start btn btn-brown"
          >
            Let's talk
          </a>
        </article>
      </div>
    </div>
  </section>

</Layout>
